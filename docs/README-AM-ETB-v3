          models / <version> / policy.pl, platform.pl, configuration.pl, ...
 
      models-api / common.pl, policy.pl, platform.pl, configuration.pl
		 / model.pl

        patterns / patterns.pl

        workflow / instantiate.pl, export.pl
		   
   	  agents / agent.pl
	         / <category> / <category>_agent.pl, ...

       assurance / assurance.pl
                 / <case> / repository.pl (* generated *)

        evidence / evidence.pl
	         / repository.pl (* generated *)
                 / <category> / <xref> / status, aargs, ... (* generated *)

           am_etb.pl

